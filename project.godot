config_version=5

[application]

config/name="Rogue Like"
run/main_scene="uid://bf02c25505kud"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://c4oselt1ds0rx"

[autoload]

Global="*uid://b3lugf1qx08i4"
Worldgen="*uid://dk61fmxhfrtqg"
EnemySpawner="*uid://q1u3yhfaxg0k"
DialogueManager="*uid://c3rodes2l3gxb"

[dialogue_manager]

runtime/balloon_path="res://Example_Dialogue_Box/balloon.tscn"

[display]

